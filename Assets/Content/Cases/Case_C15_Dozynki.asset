  m_Script: {fileID: 11500000, guid: f294f557898a8744cacfa8ab50eac7ce, type: 3}
  m_Name: Case_C15_Dozynki
  m_EditorClassIdentifier: InterrogationRoom.Game::InterrogationRoom.Content.CaseAsset
  title: "Do\u017Cynki pod podejrzeniem"
  crimeDescription: "Kto\u015B ustawi\u0142 na murawie stadionu czterdzie\u015Bci
    ogrodowych krasnali i rozegra\u0142 nimi oficjalny rzut wolny przed pe\u0142nymi
    trybunami."
  alibiFacts:
  - id: taczka-numer-12
    text: "O 16:40 grupa wesz\u0142a na konkurs dzia\u0142kowy przez bram\u0119 z
      dyni i dosta\u0142a czerwon\u0105 taczk\u0119 numer 12."
    canBeHidden: 1
    variantTexts: []
    distinctiveDetail: 0
  - id: dynia-14-kilogramow
    text: "Wsp\xF3lna dynia wa\u017Cy\u0142a dok\u0142adnie czterna\u015Bcie kilogram\xF3w."
    canBeHidden: 0
    variantTexts: []
    distinctiveDetail: 0
  - id: nadgryziona-karta
    text: "Koza odgryz\u0142a r\xF3g karty z wynikami."
    canBeHidden: 1
    variantTexts: []
    distinctiveDetail: 0
  - id: wstazka-na-porze
    text: "S\u0119dzia przywi\u0105za\u0142 niebiesk\u0105 wst\u0105\u017Ck\u0119
      do najd\u0142u\u017Cszego pora."
    canBeHidden: 0
    variantTexts: []
    distinctiveDetail: 0
  - id: deszcz-i-altana
    text: "Nag\u0142y deszcz zagoni\u0142 wszystkich pod pasiast\u0105 altan\u0119."
    canBeHidden: 1
    variantTexts: []
    distinctiveDetail: 0
  - id: lemoniada-i-wyjscie
    text: "Grupa pi\u0142a lemoniad\u0119 koperkow\u0105 ze s\u0142oik\xF3w przez
      czerwone s\u0142omki i o 17:25 wysz\u0142a zachodni\u0105 bram\u0105 za zielonym
      traktorem."
    canBeHidden: 0
    variantTexts:
    - "Grupa pi\u0142a lemoniad\u0119 koperkow\u0105 ze s\u0142oik\xF3w przez czerwone
      s\u0142omki i o 17:25 wysz\u0142a zachodni\u0105 bram\u0105 za zielonym traktorem."
    - "Grupa pi\u0142a lemoniad\u0119 koperkow\u0105 ze s\u0142oik\xF3w przez zielone
      s\u0142omki i o 17:25 wysz\u0142a zachodni\u0105 bram\u0105 za zielonym traktorem."
    distinctiveDetail: 1
  alibiClues:
  - id: plakietka-taczki
    linkedFactId: taczka-numer-12
    content: "Plakietka z czerwonymi otarciami, symbolem jednego ko\u0142a i niepe\u0142nym
      numerem 1_."
  - id: fragment-karty
    linkedFactId: nadgryziona-karta
    content: "Fragment karty z p\xF3\u0142kolistymi \u015Bladami z\u0119b\xF3w, bia\u0142\u0105
      sier\u015Bci\u0105 i urwanym wynikiem."
  - id: zdjecie-altany
    linkedFactId: deszcz-i-altana
    content: "Zdj\u0119cie kropli, pasiastych element\xF3w dachu i mokrych sylwetek."
  minHiddenFacts: 2
  maxHiddenFacts: 3
